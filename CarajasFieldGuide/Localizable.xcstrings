    },
    "about.header_body" : {
      "comment" : "Introductory paragraph in About header",
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A species-by-species reference for the confirmed snake fauna of the Serra dos Carajás, Pará, Brazil — one of the most biodiverse regions on Earth."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Um guia espécie por espécie da fauna de cobras confirmada da Serra dos Carajás, Pará, Brasil — uma das regiões mais biodiversas da Terra."
          }
        }
      }
    },
    "about.header_subtitle" : {
      "comment" : "Subtitle line under app name in About header",
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snakes of Serra dos Carajás"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cobras da Serra dos Carajás"
          }
        }
      }
    },
    "about.methodology_body" : {
      "comment" : "Body text for methodology section in About",
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Every species in this guide is confirmed by either a peer-reviewed field survey or by community observations sourced from iNaturalist. Use the filter panel to toggle species by data source — view survey records, iNaturalist observations, or the full confirmed list.\n\nWhere data is absent, fields are left blank — this guide does not estimate or extrapolate."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cada espécie neste guia foi confirmada por um levantamento de campo revisado por pares ou por observações da comunidade provenientes do iNaturalist. Use o painel de filtros para alternar as espécies por fonte de dados — veja registros de levantamento, observações do iNaturalist ou a lista completa confirmada.\n\nQuando os dados estão ausentes, os campos ficam em branco — este guia não estima nem extrapola."
          }
        }
      }
    },
    "about.methodology_title" : {
