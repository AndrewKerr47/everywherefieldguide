    "about.credits_body" : {
      "comment" : "Body text for image credits section in About",
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Species photographs are reproduced under Creative Commons licence or with explicit permission from the original photographer. All images remain the property of their respective owners and are credited accordingly."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "As fotografias das espécies são reproduzidas sob licença Creative Commons ou com permissão explícita do fotógrafo original. Todas as imagens permanecem propriedade de seus respectivos autores e são creditadas de acordo."
          }
        }
      }
    },
    "about.credits_title" : {
      "comment" : "Section label for image credits in About",
      "extractionState" : "stale",
      "localizations" : {
